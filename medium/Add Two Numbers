/*
 * Задача: Pow(x, n)
 * Сложность: Medium
 * Тема: быстрое возведение в степень, бинарное разложение степени
 *
 * Идея:
 * Используем быстрое возведение в степень.
 * Если текущий бит степени равен 1, умножаем ответ на текущее значение x.
 * Затем возводим x в квадрат и переходим к следующему биту степени.
 *
 * Степень переводится в long, чтобы корректно обработать случай Integer.MIN_VALUE.
 *
 * Временная сложность: O(log n)
 * Пространственная сложность: O(1)
 */

class Solution {
    public double myPow(double x, int n) {
        long power = n;

        if (power < 0) {
            x = 1 / x;
            power = -power;
        }

        double result = 1.0;

        while (power != 0) {
            if ((power & 1) != 0) {
                result *= x;
            }

            x *= x;
            power >>= 1;
        }

        return result;
    }
}
